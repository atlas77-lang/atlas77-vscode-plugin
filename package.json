{
  "name": "atlas77",
  "displayName": "atlas77",
  "description": "Syntax highlighting for the Atlas77 programming language",
  "repository": {
    "type": "git",
    "url": "https://github.com/atlas77-lang/atlas77-vscode-plugin"
  },
  "icon": "images/atlas77_file_logo.png",
  "version": "0.4.0",
  "publisher": "Gipson62",
  "author": "Gipson62",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "atlas",
        "aliases": [
          "Atlas77",
          "atlas77",
          "atlas",
          "atlas_77",
          "atlas-77"
        ],
        "icon": {
          "light": "images/atlas77_file_logo.png",
          "dark": "images/atlas77_file_logo.png"
        },
        "extensions": [
          ".atlas"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "atlas",
        "scopeName": "source.atlas",
        "path": "./syntaxes/atlas.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "child_process": "^1.0.2",
    "path": "^0.12.7",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vscode-languageclient": "^10.0.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.4",
    "vscode": "^1.1.36"
  },
  "scripts": {
    "build:server": "npx tsc -p server/tsconfig.json",
    "build:client": "npx tsc -p client/tsconfig.json",
    "build": "npm run build:server && npm run build:client",
    "watch": "npx tsc -w -p ."
  }
}
