{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Atlas77",
  "scopeName": "source.atlas77",
  "fileTypes": [
    "atlas"
  ],
  "patterns": [
    {
      "include": "#attributes"
    },
    {
      "include": "#doc-comments"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#extern-abi"
    },
    {
      "include": "#function-definitions"
    },
    {
      "include": "#struct-definitions"
    },
    {
      "include": "#enum-definitions"
    },
    {
      "include": "#union-definitions"
    },
    {
      "include": "#destructors"
    },
    {
      "include": "#storage-modifiers"
    },
    {
      "include": "#control-keywords"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#primitive-types"
    },
    {
      "include": "#self-keyword"
    },
    {
      "include": "#language-constants"
    },
    {
      "include": "#string-literals"
    },
    {
      "include": "#char-literals"
    },
    {
      "include": "#numeric-literals"
    },
    {
      "include": "#type-cast"
    },
    {
      "include": "#namespace-separator"
    },
    {
      "include": "#arrow"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "attributes": {
      "match": "#\\[([^\\]]+)\\]",
      "captures": {
        "0": {
          "name": "meta.attribute.atlas77"
        },
        "1": {
          "name": "entity.name.tag.attribute.atlas77"
        }
      }
    },
    "doc-comments": {
      "match": "//!.*$",
      "name": "comment.line.documentation.atlas77"
    },
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.atlas77"
    },
    "imports": {
      "match": "\\b(import)\\s+(\"[^\"]+\")",
      "captures": {
        "1": {
          "name": "keyword.control.import.atlas77"
        },
        "2": {
          "name": "string.quoted.double.import-path.atlas77"
        }
      }
    },
    "extern-abi": {
      "comment": "Matches extern \"C\" ABI strings to prevent them being highlighted as regular strings",
      "match": "\\b(extern)\\s+(\"[A-Za-z]+\")",
      "captures": {
        "1": {
          "name": "storage.modifier.atlas77"
        },
        "2": {
          "name": "string.quoted.double.abi.atlas77"
        }
      }
    },
    "function-definitions": {
      "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.other.fun.atlas77"
        },
        "2": {
          "name": "entity.name.function.atlas77"
        }
      }
    },
    "struct-definitions": {
      "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.other.struct.atlas77"
        },
        "2": {
          "name": "entity.name.type.struct.atlas77"
        }
      }
    },
    "enum-definitions": {
      "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.other.enum.atlas77"
        },
        "2": {
          "name": "entity.name.type.enum.atlas77"
        }
      }
    },
    "union-definitions": {
      "match": "\\b(union)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.other.union.atlas77"
        },
        "2": {
          "name": "entity.name.type.union.atlas77"
        }
      }
    },
    "destructors": {
      "comment": "Destructor syntax: ~TypeName()",
      "match": "~([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "0": {
          "name": "entity.name.function.destructor.atlas77"
        }
      }
    },
    "storage-modifiers": {
      "match": "\\b(public|private|extern|const)\\b",
      "name": "storage.modifier.atlas77"
    },
    "control-keywords": {
      "match": "\\b(if|else|while|for|return|let|delete|break|continue)\\b",
      "name": "keyword.control.atlas77"
    },
    "builtin-functions": {
      "comment": "Compiler intrinsics and standard primitives",
      "match": "\\b(move|copy|sizeof|size_of|alignof|align_of|panic|assert|printf|println|print|input|malloc|free|memcpy)\\b",
      "name": "support.function.builtin.atlas77"
    },
    "primitive-types": {
      "match": "\\b(uint8|uint16|uint32|uint64|int8|int16|int32|int64|float32|float64|bool|string|unit|usize|isize|FILE)\\b",
      "name": "support.type.primitive.atlas77"
    },
    "self-keyword": {
      "match": "\\bthis\\b",
      "name": "variable.language.self.atlas77"
    },
    "language-constants": {
      "match": "\\b(true|false|null)\\b",
      "name": "constant.language.atlas77"
    },
    "string-literals": {
      "name": "string.quoted.double.atlas77",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\(?:[nrt\\\\\"'0abfv]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})",
          "name": "constant.character.escape.atlas77"
        },
        {
          "match": "\\\\.",
          "name": "invalid.illegal.escape.atlas77"
        }
      ]
    },
    "char-literals": {
      "match": "'(?:[^'\\\\]|\\\\[nrt\\\\\"'0abfv])'",
      "name": "string.quoted.single.atlas77"
    },
    "numeric-literals": {
      "patterns": [
        {
          "comment": "Hexadecimal integer literal",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|u|i)?\\b",
          "name": "constant.numeric.hex.atlas77"
        },
        {
          "comment": "Floating-point literal",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:f32|f64)?\\b",
          "name": "constant.numeric.float.atlas77"
        },
        {
          "comment": "Integer literal with optional type suffix",
          "match": "\\b[0-9][0-9_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|u|i)?\\b",
          "name": "constant.numeric.integer.atlas77"
        }
      ]
    },
    "type-cast": {
      "match": "\\b(as)\\b",
      "name": "keyword.operator.cast.atlas77"
    },
    "namespace-separator": {
      "match": "::",
      "name": "punctuation.separator.namespace.atlas77"
    },
    "arrow": {
      "comment": "Used for both return type annotation and pointer member access",
      "match": "->",
      "name": "keyword.operator.arrow.atlas77"
    },
    "operators": {
      "patterns": [
        {
          "comment": "Compound assignment operators",
          "match": "(?:\\+=|-=|\\*=|/=|%=|&&=|\\|\\|=|&=|\\|=|\\^=|<<=|>>=)",
          "name": "keyword.operator.assignment.compound.atlas77"
        },
        {
          "comment": "Comparison and logical operators",
          "match": "(?:==|!=|<=|>=|&&|\\|\\|)",
          "name": "keyword.operator.logical.atlas77"
        },
        {
          "comment": "Assignment",
          "match": "(?<![=!<>])=(?!=)",
          "name": "keyword.operator.assignment.atlas77"
        },
        {
          "comment": "Arithmetic, bitwise, pointer, reference operators",
          "match": "[+\\-*/%&|^!~<>]",
          "name": "keyword.operator.atlas77"
        }
      ]
    }
  }
}