{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Atlas77",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#primitive-types"
		},
		{
			"include": "#intrinsic-operators"
		},
		{
			"include": "#language-constants"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#punctuation"
		},
		{
			"include": "#numbers"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.atlas77",
					"match": "\\b(import|let|while|fun|struct|union|enum|public|extern|const|if|as|return|this|else|delete|this|namespace|private|where|concept|operator|when|then|comptime)\\b"
				}
			]
		},
		"intrinsic-operators": {
			"patterns": [
				{
					"name": "support.function.builtin.atlas77",
					"match": "\\b(size_of|align_of|type_of|type_id|panic)\\b"
				}
			]
		},
		"primitive-types": {
			"patterns": [
				{
					"match": "\\b(?:u?int(?:8|16|32|64)|float(?:32|64)|str|char|unit|bool)\\b",
					"name": "support.type.primitive.atlas77"
				}
			]
		},
		"language-constants": {
			"patterns": [
				{
					"match": "\\b(true|false|null)\\b",
					"name": "constant.language.atlas77"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.atlas77",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.atlas77",
					"match": "\\\\."
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line.atlas77",
					"match": "//.*"
				},
				{
					"name": "comment.block.atlas77",
					"match": "/\\*.*\\*/"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.double-colon.atlas77",
					"match": "::"
				},
				{
					"name": "punctuation.separator.colon.atlas77",
					"match": ":"
				},
				{
					"name": "punctuation.separator.comma.atlas77",
					"match": ","
				},
				{
					"name": "punctuation.access.dot.atlas77",
					"match": "\\."
				},
				{
					"name": "punctuation.terminator.semicolon.atlas77",
					"match": ";"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.atlas77",
					"match": "\\b(\\d+(?:_\\d+)*\\.\\d+(?:_\\d+)*(?:[eE][+-]?\\d+(?:_\\d+)*)?)([uUlL]+)?\\b",
					"captures": {
						"1": {
							"name": "constant.numeric.float.atlas77"
						},
						"2": {
							"name": "storage.type.numeric-suffix.atlas77"
						}
					}
				},
				{
					"name": "constant.numeric.float.leading-dot.atlas77",
					"match": "\\b\\.\\d+(?:_\\d+)*(?:[eE][+-]?\\d+(?:_\\d+)*)?[fF]?\\b"
				},
				{
					"name": "constant.numeric.hex.atlas77",
					"match": "\\b0x[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*\\b"
				},
				{
					"name": "constant.numeric.binary.atlas77",
					"match": "\\b0b[01]+(?:_[01]+)*\\b"
				},
				{
					"name": "constant.numeric.octal.atlas77",
					"match": "\\b0o[0-7]+(?:_[0-7]+)*\\b"
				},
				{
					"name": "constant.numeric.integer.atlas77",
					"match": "\\b(\\d+(?:_\\d+)*)([uUlL]+)?\\b",
					"captures": {
						"1": {
							"name": "constant.numeric.integer.atlas77"
						},
						"2": {
							"name": "storage.type.numeric-suffix.atlas77"
						}
					}
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "meta.function-call.atlas77",
					"begin": "(?=[A-Za-z_][A-Za-z0-9_]*(::[A-Za-z_][A-Za-z0-9_]*)*\\s*\\()",
					"end": "(?=\\()",
					"patterns": [
						{
							"match": "[A-Za-z_][A-Za-z0-9_]*(?=::)",
							"name": "entity.name.namespace.atlas77"
						},
						{
							"match": "::",
							"name": "punctuation.separator.double-colon.atlas77"
						},
						{
							"match": "[A-Za-z_][A-Za-z0-9_]*",
							"name": "entity.name.function.atlas77"
						}
					]
				}
			]
		}
	},
	"scopeName": "source.atlas"
}